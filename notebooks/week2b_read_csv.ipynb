    {
      "cell_type": "code",
      "source": [
        "# 🧹 Шаг 2B. Очистка и переименование столбцов\n",
        "\n",
        "# Переименовываем столбцы, убирая постфикс Label\n",
        "df_volcano = df_volcano.rename(columns={\n",
        "    \"volcanoLabel\": \"volcano\",\n",
        "    \"continentLabel\": \"continent\",\n",
        "    \"mountainRangeLabel\": \"mountainRange\"\n",
        "})\n",
        "\n",
        "# Приводим высоту к целочисленному типу\n",
        "df_volcano[\"elevation\"] = pd.to_numeric(\n",
        "    df_volcano[\"elevation\"], errors=\"coerce\"\n",
        ").fillna(0).astype(int)\n",
        "\n",
        "# Удаляем столбец с URL Wikidata (volcano), если он существует\n",
        "if \"volcano\" in df_volcano.columns and \"volcano\" in df_volcano.columns.tolist()[0]:\n",
        "    # Проверяем, не путаем ли мы переименованный столбец с исходным URL-столбцом\n",
        "    pass  # В вашем файле такого столбца нет, поэтому пропускаем\n",
        "\n",
        "print(\"✅ Данные очищены и готовы к анализу\")\n",
        "print(\"\\n📋 Текущие столбцы:\", list(df_volcano.columns))\n",
        "print(\"\\n🔍 Пример данных после очистки:\")\n",
        "print(df_volcano.head(3))"
      ],
      "metadata": {
        "id": "xwl4nCuFL16h",
        "outputId": "2bee2105-9b46-4f62-a883-2085578f207b",
        "# 1) df_genre: жанры, страны, продолжительность\n",
        "if \"filmLabel\" in df_genre.columns:                             # Проверка: нужна ли очистка?\n",
        "    # URL Wikidata не удаляем, а переименовываем в \"URL\" для удобства\n",
        "    df_genre = df_genre.rename(columns={\n",
        "        \"film\": \"URL\",          # ← переименовали технический столбец\n",
        "        \"filmLabel\": \"film\",\n",
        "        \"genreLabel\": \"genre\",\n",
        "        \"countryLabel\": \"country\",\n",
        "    })\n",
        "    df_genre[\"duration\"] = pd.to_numeric(\n",
        "        df_genre[\"duration\"], errors=\"coerce\"\n",
        "    ).fillna(0).astype(int)\n",
        "    print(\"✅ df_genre очищен\")\n",
        "else:\n",
        "    print(\"⏭️ df_genre уже очищен, пропускаем\")\n",
        "\n",
        "# 2) df_assessment: год выпуска, оценки и рейтинги\n",
        "if \"filmLabel\" in df_assessment.columns:                        # Проверка: нужна ли очистка?\n",
        "    # URL Wikidata не удаляем, а переименовываем в \"URL\" для удобства\n",
        "    df_assessment = df_assessment.rename(columns={\n",
        "        \"film\": \"URL\",          # ← переименовали технический столбец\n",
        "        \"filmLabel\": \"film\",\n",
        "        \"assessmentLabel\": \"assessment\",\n",
        "        \"outcomeLabel\": \"outcome\",\n",
        "    })\n",
        "    df_assessment[\"publicationYear\"] = pd.to_numeric(\n",
        "        df_assessment[\"publicationYear\"], errors=\"coerce\"\n",
